# =============================================================================
# API Server
# =============================================================================
API_PORT=3001
API_KEY=your-api-key-here

# =============================================================================
# Exchange API Keys (trade-only, NO withdrawal permissions)
# =============================================================================
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_SANDBOX=false

OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=

BYBIT_API_KEY=
BYBIT_API_SECRET=

# =============================================================================
# Encryption (AES-256-GCM key for storing API keys at rest)
# Must be exactly 32 characters
# =============================================================================
ENCRYPTION_KEY=your-32-char-encryption-key-here

# =============================================================================
# Telegram Notifications
# =============================================================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# =============================================================================
# Trading Parameters (fallback defaults — override via Strategy Config UI)
# =============================================================================
REBALANCE_THRESHOLD=5
REBALANCE_COOLDOWN_HOURS=1
MIN_TRADE_USD=10
MAX_TRADE_USD=5000
DAILY_LOSS_LIMIT_PCT=10
PAPER_TRADING=true

# =============================================================================
# Database (MongoDB)
# =============================================================================
MONGO_PASSWORD=your-mongo-password-here
MONGODB_URI=mongodb://admin:your-mongo-password-here@mongodb:27017/rebalance?authSource=admin

# =============================================================================
# OpenClaw AI Agent (optional — start with: docker compose --profile full up)
# =============================================================================
ANTHROPIC_API_KEY=
OPENCLAW_GATEWAY_TOKEN=changeme
