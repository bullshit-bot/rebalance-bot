# =============================================================================
# API Server
# =============================================================================
API_PORT=3001
API_KEY=your-api-key-here

# =============================================================================
# Exchange API Keys (trade-only, NO withdrawal permissions)
# =============================================================================
BINANCE_API_KEY=
BINANCE_API_SECRET=

OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=

BYBIT_API_KEY=
BYBIT_API_SECRET=

# =============================================================================
# Encryption (AES-256-GCM key for storing API keys at rest)
# Must be exactly 32 characters
# =============================================================================
ENCRYPTION_KEY=your-32-char-encryption-key-here

# =============================================================================
# Telegram Notifications
# =============================================================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# =============================================================================
# Trading Parameters
# =============================================================================
# Drift threshold (%) before triggering rebalance
REBALANCE_THRESHOLD=5

# Minimum hours between automatic rebalances
REBALANCE_COOLDOWN_HOURS=1

# Min/max trade size in USD
MIN_TRADE_USD=10
MAX_TRADE_USD=5000

# Daily portfolio loss limit (%) — circuit breaker
DAILY_LOSS_LIMIT_PCT=10

# Paper trading mode (true = simulated, false = live trading)
PAPER_TRADING=true

# =============================================================================
# Database
# =============================================================================
DATABASE_URL=file:./data/bot.db
