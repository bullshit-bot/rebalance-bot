{
  "name": "rebalance-bot",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun run dist/index.js",
    "seed": "bun run scripts/seed-dev-data.ts",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "test": "bun test ./src/ --path-ignore-patterns='**/*.isolated.test.ts'",
    "test:cov": "bun test ./src/ --path-ignore-patterns='**/*.isolated.test.ts' --coverage",
    "test:cov:html": "bun test ./src/ --path-ignore-patterns='**/*.isolated.test.ts' --coverage --coverage-reporter=lcov --coverage-dir=coverage && genhtml coverage/lcov.info -o coverage/html --quiet && echo 'Report: coverage/html/index.html'",
    "test:isolated": "for f in $(find src -name '*.isolated.test.ts'); do bun test $f; done"
  },
  "dependencies": {
    "@t3-oss/env-core": "^0.11.0",
    "ccxt": "^4.4.0",
    "croner": "^9.0.0",
    "hono": "^4.7.0",
    "mongoose": "^9.3.3",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/bun": "latest",
    "typescript": "^5.7.0"
  }
}
